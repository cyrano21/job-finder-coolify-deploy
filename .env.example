# ──────────────────────────────────────────────────────────────
# Base de données — Supabase Postgres (Prisma)
# Supabase > Project Settings > Database > Connection string
#   - DATABASE_URL : "Transaction pooler" (port 6543) pour l'app
#   - DIRECT_URL   : "Session / Direct" (port 5432) pour les migrations
# ──────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# ──────────────────────────────────────────────────────────────
# Supabase (auth + client)
# ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ──────────────────────────────────────────────────────────────
# IA — fournisseur actif (API compatible OpenAI)
# AI_PROVIDER : groq | openai | deepseek | mistral | xai | gemini | openrouter
# AI_MODEL    : (optionnel) force un modèle précis pour le fournisseur choisi
# ──────────────────────────────────────────────────────────────
AI_PROVIDER="groq"
# AI_MODEL="llama-3.3-70b-versatile"
GROQ_API_KEY="gsk_..."
OPENAI_API_KEY="sk-proj-..."
DEEPSEEK_API_KEY="sk-..."
MISTRAL_API_KEY="..."
GROK_API_KEY="xai-..."
GEMINI_API_KEY="AIza..."
OPENROUTER_API_KEY="sk-or-v1-..."
HUGGINGFACE_API_KEY="hf_..."

# ──────────────────────────────────────────────────────────────
# APIs d'offres d'emploi
# ──────────────────────────────────────────────────────────────
ADZUNA_APP_ID="your-adzuna-app-id"
ADZUNA_APP_KEY="your-adzuna-app-key"
SEARCHAPI_API_KEY="your-searchapi-key"
JOOBLE_API_KEY="your-jooble-key"

# ──────────────────────────────────────────────────────────────
# Stripe
# ──────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ──────────────────────────────────────────────────────────────
# Google Maps (géolocalisation)
# ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="your-google-maps-key"

# ──────────────────────────────────────────────────────────────
# Email SMTP (alertes emploi)
# ──────────────────────────────────────────────────────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER="you@example.com"
SMTP_PASS="your-app-password"
SMTP_FROM="MonSite <no-reply@monsite.com>"

# Secret partagé pour déclencher /api/jobs/notify (cron)
CRON_SECRET="change-me-to-a-long-random-string"

# ──────────────────────────────────────────────────────────────
# Application
# ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3005"
